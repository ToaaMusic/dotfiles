#!/usr/bin/env bash
set -euo pipefail

readonly dotfiles_repo_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
readonly dotfiles_config_dir="$dotfiles_repo_dir/config"
readonly dotfiles_home_dir="$dotfiles_repo_dir/home"
readonly dot_config_dir="$HOME/.config"
readonly desktop_entry_dir="$HOME/.local/share/applications"

# opts
run_mode="link"
force_bool=false
select_bool=false

mkdir -p "$dot_config_dir" "$desktop_entry_dir"

# get the name of the parent directory
# params:
#   $1 - path
parentname() {
  local path="$1"
  local clean_path="${path%/}" # trim "/"
  local parent_path=$(dirname "$clean_path")
  basename "$parent_path"
}

# list all component paths
# globals:
#   dotfiles_config_dir - dotfiles config directory
#   dotfiles_home_dir   - dotfiles home directory
echo_path_list() {
  for dir in "$dotfiles_config_dir"/*; do
    echo "$dir"
  done
  for file in "$dotfiles_home_dir"/.*; do
    echo "$file"
  done
}

# list configs from this host
# globals:
#   dot_config_dir - $HOME/.config/
echo_target_path_list() {
  for dir in "$dot_config_dir"/*; do
    echo "$dir"
  done
  for file in "$HOME"/.*; do
    echo "$file"
  done
}

# check path type
# params:
#   $1 - path to check
# returns:
#   echo type: "symlink"|"file"|"non-empty directory"|"empty directory"|""
echo_path_type() {
  local path="$1"
  if [[ -L "$path" ]]; then
    echo "symlink"
  elif [[ -f "$path" ]]; then
    echo "file"
  elif [[ -d "$path" ]]; then
    if [[ "$(ls -A "$path" 2>/dev/null)" ]]; then
      echo "non-empty directory"
    else
      echo "empty directory"
    fi
  else
    echo ""
  fi
}

# ask for removing existing path
# params:
#   $1 - path to remove
#   $2 - force remove or not
# returns:
#   0  - removed successfully
#   1  - skipped or failed
ask_rm() {
  local path="$1"
  local force="${2:-false}"
  local path_type="$(echo_path_type "$path")"
  local name="$(basename "$path")"
  if [[ -z "$path_type" ]]; then
    return 0
  fi
  if [[ "$force" == "true" ]] || [[ $path_type == "empty directory" ]]; then
    if rm -rf "$path" 2>/dev/null; then
      echo "✓ Removed $path_type: $name"
      return 0
    else
      return 1
    fi
  fi
  read -rp "$name exists as a $path_type. Override? [y/N] " answer
  case "$answer" in
  [Yy]*)
    if rm -rf "$path" 2>/dev/null; then
      echo "✓ Removed existing $path_type: $name"
      return 0
    else
      echo "✗ Failed to rm $name (permission denied?), skipping" >&2
      return 1
    fi
    ;;
  *)
    echo "→ Skipped $name"
    return 1
    ;;
  esac
}

# link a single source path to its target
# params:
#   $1 - source path (must be under config/ or home/)
# globals:
#   dot_config_dir - $HOME/.config/
#   force_bool     - global force flag
link_item() {
  local src="$1"
  local name
  name="$(basename "$src")"
  local parent_name
  parent_name="$(parentname "$src")"
  local target
  if [[ "$parent_name" == "config" ]]; then
    target="$dot_config_dir/$name"
  else
    target="$HOME/$name"
  fi
  ask_rm "$target" "$force_bool" || return
  ln -s "$src" "$target"
  echo "Linked $name -> $target"
}

# create toaam-dotfiles.desktop file
# globals:
#   desktop_entry_dir - $HOME/.local/share/applications
create_desktop_entry() {
  mkdir -p "$desktop_entry_dir"

  cat >"$desktop_entry_dir/toaam-dotfiles.desktop" <<'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Zed: Edit Dotfiles
Comment=Open Dotfiles project in Zed
Exec=zsh -lc 'zeditor "$TOAAM_DOTFILES"'
Icon=zed
Terminal=false
Categories=Development;TextEditor;
Keywords=dotfiles;config;zed;
EOF

  chmod +x "$desktop_entry_dir/toaam-dotfiles.desktop"
  echo "Generated desktop entry"
}

# main linker
main_link() {
  for src in $(echo_path_list); do
    link_item "$src"
  done
  create_desktop_entry
}

# interactive selector with checkbox-style UI
show_select() {
  local items=("$@")
  local selected=()
  local cursor=0
  local num_items=${#items[@]}

  if [[ $num_items -eq 0 ]]; then
    echo "No items found to link."
    return
  fi

  for ((i = 0; i < num_items; i++)); do
    selected+=(false)
  done

  cleanup_tui() {
    tput cnorm
  }
  trap cleanup_tui EXIT
  tput civis

  while true; do
    clear
    echo -e "\e[1;36m?\e[0m \e[1mSelect configurations to link:\e[0m"
    echo -e "\e[90m(Space: Toggle, a: All, i: Invert, q: Quit, Enter: Apply)\e[0m"
    echo

    # render items
    local i
    for i in "${!items[@]}"; do
      local ptr
      if [[ "$i" -eq "$cursor" ]]; then
        ptr="\e[1;36m>\e[0m"
      else
        ptr=" "
      fi
      if [[ "${selected[$i]}" == true ]]; then
        echo -e " $ptr [\e[1;32m✔\e[0m] \e[1m${items[$i]}\e[0m"
      else
        echo -e " $ptr [ ] \e[90m${items[$i]}\e[0m"
      fi
    done

    echo

    # handle input key
    local key
    IFS= read -rsn1 key
    case "$key" in
    $'\x1b')
      IFS= read -rsn2 key
      case "$key" in
      "[A") cursor=$(((cursor - 1 + num_items) % num_items)) ;;
      "[B") cursor=$(((cursor + 1) % num_items)) ;;
      esac
      ;;
    " ")
      if [[ "${selected[$cursor]}" == true ]]; then
        selected[$cursor]=false
      else
        selected[$cursor]=true
      fi
      ;;
    "a")
      local all_on=true
      local s
      for s in "${selected[@]}"; do
        [[ "$s" == false ]] && all_on=false && break
      done
      local j
      for ((j = 0; j < num_items; j++)); do
        if [[ "$all_on" == true ]]; then
          selected[$j]=false
        else
          selected[$j]=true
        fi
      done
      ;;
    "i")
      local j
      for ((j = 0; j < num_items; j++)); do
        if [[ "${selected[$j]}" == true ]]; then
          selected[$j]=false
        else
          selected[$j]=true
        fi
      done
      ;;
    "q")
      echo "Cancelled."
      exit 0
      ;;
    "")
      break
      ;;
    *)
      ;;
    esac
  done

  cleanup_tui
  trap - EXIT
  # clear

  local any=false
  local i
  for i in "${!items[@]}"; do
    if [[ "${selected[$i]}" != true ]]; then
      continue
    fi
    any=true
    link_item "${items[$i]}"
  done

  if [[ "$any" == false ]]; then
    echo "No items selected."
  else
    echo -e "\n\e[1;32mDone\e[0m"
  fi
}

cmd_clean() {
  for item in $(echo_target_path_list); do
    if [[ -L "$item" ]] && [[ "$(readlink "$item")" == "$dotfiles_repo_dir"* ]]; then
      ask_rm "$item" "$force_bool" || return
      echo "✓ Removed symlink: $item"
    fi
  done
}

cmd_add() {
  echo "not implemented yet"
  exit 1
}

# show help menu
show_usage() {
  cat <<'EOF'
Usage: ./link [command] [options]

Dotfiles linker script - creates symbolic links for configuration files.

Commands:
  (no args)      # Default: link all configs, home files, and generate desktop entry
  ls             # List all component paths that would be linked (Ignore all opts)
  clean          # Remove all symlinks managed by this repo
  add [path]     # NOT IMPLEMENTED YET: Add a directory or file to this repo

Options:
  -f, --force    # Force overwrite without confirmation
  -s, --select   # Interactive selector mode (checkbox-style UI)
  -h, --help     # Show this help message 

Examples:
  ./link         # Link without selecting by default
  ./link ls      # Echo all source paths
  ./link ls -h   # each commands allows -h or --help for help

Report issues at: [https://github.com/ToaaMusic/dotfiles]
EOF
}

cmd_ls_help() {
  cat <<'EOF'
Usage: ./link ls

List all component paths that would be linked (Ignore all opts)

Options:
  -h, --help       # Show this help message

Examples:
  ./link ls | fzf  # filter by fzf
EOF
}

cmd_clean_help() {
  cat <<'EOF'
Usage: ./link clean

- Remove all symlinks and files managed by this repo
- Restore the original state (if backed up) - planned

Options:
  -f, --force      # Force remove the link
  -h, --help       # Show this help message

Examples:
  ./link clean -f
EOF
}

cmd_add_help() {
  cat <<'EOF'
Usage: ./link add [directory_name or file_name]

⚠ This command is still not implemented yet.

Add specified directory or file to the dotfiles repo (planned features):
  - Move the directory/file to this repo
  - Create a symbolic link in the original location
  - Support for multiple addition: ./link add dir1 dir2

Options:
  -h, --help       # Show this help message

Examples:
  ./link add nvim
  ./link add .bashrc .zshrc
EOF
}

main() {
  temp=$(getopt -o fsh --long force,select,help -n "$0" -- "$@") || {
    show_usage
    exit 1
  }
  eval set -- "$temp"

  while true; do
    case "$1" in
    -f | --force) force_bool=true && shift ;;
    -s | --select) select_bool=true && shift ;;
    -h | --help) run_mode="help" && shift ;;
    --) shift && break ;;
    *) break ;;
    esac
  done

  case "${1:-}" in
  ls) # sub cmds
    if [[ $run_mode == "help" ]]; then
      cmd_ls_help
      exit 0
    fi
    echo_path_list
    ;;
  clean)
    if [[ $run_mode == "help" ]]; then
      cmd_clean_help
      exit 0
    fi
    cmd_clean
    ;;
  add)
    if [[ $run_mode == "help" ]]; then
      cmd_add_help
      exit 0
    fi
    shift
    cmd_add "$@"
    ;;
  "") # main cmd
    if [[ $run_mode == "help" ]]; then
      show_usage
      exit 0
    fi
    if [[ $select_bool == "true" ]]; then
      show_select $(echo_path_list)
    else
      main_link
    fi
    ;;
  *)
    echo "Error: Unknown command '$1'" >&2
    echo "Run './link -h' for usage information." >&2
    exit 1
    ;;
  esac
}

# if not source
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
