## Configuration file for CAVA.
# Remove the ; to change parameters.

# See: https://github.com/karlstav/cava/blob/master/example_files/config
# Shaders see: https://github.com/karlstav/cava/tree/master/output/shaders
# Themes see: https://github.com/karlstav/cava/tree/master/output/themes

[general]

# Enables run-time reload of this config file.
live-config = 1

# fps
framerate = 60

# 'normal', 'scientific' or 'waves'
mode = normal

; autosens = 1
; overshoot = 20
sensitivity = 200

# bars
bars = 0
bar_width = 1
bar_spacing = 0
; bar_height = 32
; center_align = 1
max_height = 100
# Lower and higher cutoff frequencies for lowest and highest bars
; lower_cutoff_freq = 50
; higher_cutoff_freq = 10000

# bool, seconds with no input before cava goes to sleep mode. 
; sleep_timer = 0


[input]

; method = pulse
; source = auto

; method = pipewire
; source = auto

; method = alsa
; source = hw:Loopback,1

; method = fifo
; source = /tmp/mpd.fifo

; method = shmem
; source = /squeezelite-AA:BB:CC:DD:EE:FF

; method = portaudio
; source = auto

; method = sndio
; source = default

; method = oss
; source = /dev/dsp

; method = jack
; source = default

; sample_rate = 44100
; sample_bits = 16
; channels = 2
; autoconnect = 2
; active = 0
; remix = 1
; virtual = 1


[output]

; method = noncurses
; orientation = bottom

channels = mono
mono_option = average
reverse = 0

; raw_target = /dev/stdout
; data_format = binary
; bit_format = 16bit
; ascii_max_range = 1000
; bar_delimiter = 59
; frame_delimiter = 10

; sdl_width = 1024
; sdl_height = 512
; sdl_x = -1
; sdl_y= -1
; sdl_full_screen = 0

; xaxis = none
 
; synchronized_sync = 0

; vertex_shader = pass_through.vert
; fragment_shader = bar_spectrum.frag

; for glsl output mode, keep rendering even if no audio
; continuous_rendering = 0

; disable_blanking = 0

show_idle_bar_heads = 0

; waveform = 0

[color]

; background = default
; foreground = default

; gradient = 0
; gradient_color_1 = '#59cc33'
; gradient_color_2 = '#80cc33'
; gradient_color_3 = '#a6cc33'
; gradient_color_4 = '#cccc33'
; gradient_color_5 = '#cca633'
; gradient_color_6 = '#cc8033'
; gradient_color_7 = '#cc5933'
; gradient_color_8 = '#cc3333'

; horizontal_gradient = 0
; horizontal_gradient_color_1 = '#c45161'
; horizontal_gradient_color_2 = '#e094a0'
; horizontal_gradient_color_3 = '#f2b6c0'
; horizontal_gradient_color_4 = '#f2dde1'
; horizontal_gradient_color_5 = '#cbc7d8'
; horizontal_gradient_color_6 = '#8db7d2'
; horizontal_gradient_color_7 = '#5e62a9'
; horizontal_gradient_color_8 = '#434279'

; blend_direction = 'up'

theme = 'colors.g.theme'


[smoothing]

; integral = 77

; monstercat = 0
; waves = 0

; gravity = 100

ignore = 8

noise_reduction = 28


[eq]

1 = 1 # bass
2 = 1
3 = 1 # midtone
4 = 1
5 = 1 # treble
